# Environment variables for Mitra Frontend
# Copy this file to .env.local and update values as needed

# React App Configuration
REACT_APP_NAME=Mitra

# API Configuration
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_VERSION=1.0.0

# API Configuration (for future backend integration)
# REACT_APP_API_URL=http://localhost:3001/api
# REACT_APP_AUTH_ENDPOINT=/auth
# REACT_APP_ROOMS_ENDPOINT=/rooms
# REACT_APP_BOOKINGS_ENDPOINT=/bookings

# Feature Flags
# REACT_APP_ENABLE_REAL_AUTH=false
# REACT_APP_ENABLE_NOTIFICATIONS=false